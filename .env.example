# Server-only (no exponer al cliente)
RESEND_API_KEY=
# Remitente del form de contacto. Debe estar verificado en Resend.
# Mientras no esté verificado, deja vacío y se usará onboarding@resend.dev.
CONTACT_FROM_EMAIL=
# Destinatario del form de contacto (dónde caen los mensajes).
# NO lleva prefijo NEXT_PUBLIC: es un destino de servidor, no se expone al cliente.
# Si se deja vacío, se usa jose@jjpg.dev (el correo que el sitio anuncia).
CONTACT_TO_EMAIL=jose@jjpg.dev

# Públicas (se inlinean en el build)
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-handle/discovery-call
# Correo público mostrado (Footer). Distinto del destinatario del form de arriba.
NEXT_PUBLIC_CONTACT_EMAIL=jose@jjpg.dev
